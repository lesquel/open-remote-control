{
  "name": "@lesquel/opencode-pilot",
  "version": "1.16.2",
  "description": "Remote control web dashboard for OpenCode — multi-project tabs, live SSE streaming, mobile-friendly, push/Telegram notifications, tunnel for phone access from anywhere.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    "./server": "./src/server/index.ts",
    "./tui": "./src/tui/index.ts"
  },
  "main": "./src/server/index.ts",
  "bin": {
    "opencode-pilot": "./src/cli/init.ts"
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "engines": {
    "opencode": ">=0.1.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "bun test",
    "prepublishOnly": "bun scripts/prepublish-guard.ts && tsc --noEmit && bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesquel/open-remote-control.git"
  },
  "bugs": {
    "url": "https://github.com/lesquel/open-remote-control/issues"
  },
  "homepage": "https://github.com/lesquel/open-remote-control#readme",
  "author": {
    "name": "lesquel",
    "url": "https://github.com/lesquel"
  },
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/lesquel"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ai-agent",
    "remote-control",
    "dashboard",
    "web-dashboard",
    "mobile",
    "pwa",
    "telegram",
    "telegram-bot",
    "web-push",
    "push-notifications",
    "sse",
    "server-sent-events",
    "cloudflared",
    "ngrok",
    "tunnel",
    "qr-code",
    "permissions",
    "agent-monitoring",
    "multi-project",
    "developer-tools",
    "claude",
    "anthropic"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.8.0"
  }
}
