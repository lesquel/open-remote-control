{
  "name": "opencode-pilot",
  "version": "1.6.1",
  "description": "Remote control plugin for OpenCode — monitor sessions, send prompts, approve permissions, and get Telegram notifications from anywhere",
  "type": "module",
  "exports": {
    "./server": "./src/server/index.ts",
    "./tui": "./src/tui/index.ts"
  },
  "main": "./src/server/index.ts",
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "opencode": ">=0.1.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lesquel/open-remote-control"
  },
  "bugs": {
    "url": "https://github.com/lesquel/open-remote-control/issues"
  },
  "homepage": "https://github.com/lesquel/open-remote-control#readme",
  "author": "lesquel",
  "license": "MIT",
  "keywords": [
    "opencode",
    "plugin",
    "remote-control",
    "monitoring",
    "dashboard",
    "telegram",
    "sse",
    "tunnel",
    "permissions"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/bun": "latest",
    "@types/web-push": "^3.6.4"
  }
}
