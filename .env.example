# ─────────────────────────────────────────────────────────────────
# OpenCode Pilot — Environment Configuration Template
#
# Copy this file to `.env` or `.env.local` and fill in the values.
# `.env` is already in .gitignore — never commit real secrets.
# ─────────────────────────────────────────────────────────────────

# ─── Server ─────────────────────────────────────────────────────
# HTTP port the pilot dashboard listens on.
PILOT_PORT=4097
# Bind address. Default is loopback (safe). Set to 0.0.0.0 for LAN,
# but only behind a firewall or tunnel.
PILOT_HOST=127.0.0.1

# ─── Permissions ────────────────────────────────────────────────
# How long a permission request waits for Allow/Deny before timing
# out (ms). 300000 = 5 min.
PILOT_PERMISSION_TIMEOUT=300000

# ─── Tunnel (optional) ──────────────────────────────────────────
# Expose the dashboard over the public internet. Uncomment ONE.
# Each requires the respective CLI installed and authenticated.
# PILOT_TUNNEL=cloudflared
# PILOT_TUNNEL=ngrok

# ─── Telegram (optional — both required together) ──────────────
# How to get them:
#   1. Talk to @BotFather → /newbot → follow prompts → copy TOKEN
#   2. Send any message to your bot, then open in a browser:
#        https://api.telegram.org/bot<TOKEN>/getUpdates
#      Find "chat":{"id": <number>} → that number is your CHAT_ID.
# PILOT_TELEGRAM_TOKEN=123456:ABC-DEF_ghi_JKLmno
# PILOT_TELEGRAM_CHAT_ID=123456789

# ─── Web Push (VAPID — optional) ───────────────────────────────
# Required to deliver push notifications when the dashboard tab is
# closed or the device is locked.
#
# How to generate your keys (pick ONE):
#
#   Option A — with Bun (no install needed):
#     bun -e "
#     function b64url(b){return Buffer.from(b).toString('base64').replace(/\+/g,'-').replace(/\//g,'_').replace(/=+\$/,'')}
#     const {publicKey,privateKey}=await crypto.subtle.generateKey({name:'ECDSA',namedCurve:'P-256'},true,['sign','verify']);
#     const pub=await crypto.subtle.exportKey('raw',publicKey);
#     const jwk=await crypto.subtle.exportKey('jwk',privateKey);
#     const priv=Buffer.from(jwk.d.replace(/-/g,'+').replace(/_/g,'/')+'==='.slice((jwk.d.length+3)%4),'base64');
#     console.log('PUBLIC =',b64url(pub));console.log('PRIVATE=',b64url(priv));
#     "
#
#   Option B — with web-push CLI:
#     npx web-push generate-vapid-keys
#
# Paste the resulting values below. Keep PRIVATE_KEY secret — anyone
# with it can send pushes to your subscribed devices.
#
# PILOT_VAPID_PUBLIC_KEY=
# PILOT_VAPID_PRIVATE_KEY=
# Contact address that push services may reach you at if they detect
# abuse. Your real email is fine; the placeholder below also works.
PILOT_VAPID_SUBJECT=mailto:admin@opencode-pilot.local

# ─── Glob file opener (off by default) ─────────────────────────
# When true, the dashboard exposes /fs/glob and /fs/read so users
# can glob-search and open arbitrary files under the project dir
# OR $HOME. Paths are realpath-sandboxed and every access audited.
# Enable ONLY on trusted dev machines.
PILOT_ENABLE_GLOB_OPENER=false

# ─── Dev & timeouts ─────────────────────────────────────────────
# When true, dashboard HTML is re-read on every request (editing).
PILOT_DEV=false
# External HTTP call timeout (Telegram API, tunnels, etc.) in ms.
PILOT_FETCH_TIMEOUT_MS=10000
