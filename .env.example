# OpenCode Pilot — Environment Configuration
# Copy to .env.local or export these before starting OpenCode

# Server
PILOT_PORT=4097
PILOT_HOST=127.0.0.1

# Permissions
PILOT_PERMISSION_TIMEOUT=300000

# Tunnel (optional — expose to internet)
# PILOT_TUNNEL=cloudflared
# PILOT_TUNNEL=ngrok

# Telegram (optional, both required for notifications)
# PILOT_TELEGRAM_TOKEN=123456:ABC-DEF...
# PILOT_TELEGRAM_CHAT_ID=123456789
